# TruSkills — Staging Environment Variables
# NON-PRODUCTION. Copy to .env.staging and fill in values.
# All keys here are sandbox/test keys. No production credentials in this file.

NODE_ENV=staging

# ── Database ─────────────────────────────────────────────────────────────────
# Default: local Postgres running on standard port. Change user/pass to match your local instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/truskills_staging

# ── Auth ─────────────────────────────────────────────────────────────────────
# Run once to generate: openssl rand -hex 64
JWT_SECRET=change_me_run_openssl_rand_hex_64

# ── Payment — Moyasar sandbox ─────────────────────────────────────────────────
# Sign up free at moyasar.com → Dashboard → API Keys → copy Test Secret Key
PAYMENT_SANDBOX_API_KEY=sk_test_REPLACE_WITH_MOYASAR_TEST_KEY

# ── Storage — local filesystem ────────────────────────────────────────────────
# No external account needed. Files written to LOCAL_STORAGE_DIR.
LOCAL_STORAGE_DIR=./tmp/storage
LOCAL_STORAGE_BASE_URL=http://localhost:3000/static/storage

# ── Notifications — console/log ───────────────────────────────────────────────
# No external account needed. Notifications printed to stdout + log file.
NOTIFICATION_LOG_FILE=./tmp/notifications.log

# ── Video — mock (in-memory) ──────────────────────────────────────────────────
# No external account needed for staging. MockVideoAdapter used.
# Replace when video vendor confirmed (Daily.co free tier recommended).
# VIDEO_API_KEY=
# VIDEO_CDN_ENDPOINT=

# ── Platform commercial constants ────────────────────────────────────────────
# Staging values — not binding for production
PLATFORM_FEE_RATE=0.10
PAYOUT_MINIMUM_THRESHOLD=10000
PAYOUT_SCHEDULE_DAYS=7
BOOST_DAILY_SPEND_CAP=1000000

# ── Ops ───────────────────────────────────────────────────────────────────────
OPS_TOKEN=REPLACE_WITH_STAGING_OPS_TOKEN
